		<script>
			function generateOutput() {
				const form = document.getElementById('promptForm');
				const formData = new FormData(form);
				let output = '';

				output += 'Act as: ' + (formData.get('persona') || 'Not selected') + '\n';
				output += 'with also experience as: ' + (formData.get('persona2') || 'Not selected') + '\n';
				output += 'with also experience as: ' + (formData.get('persona3') || 'Not selected') + '\n';
				output += 'to perform task: ' + (formData.get('task') || 'Not selected') + '\n';
				output += 'Format: ' + (formData.get('format') || 'Not selected') + '\n';
				output += 'using tone: ' + (formData.get('tone') || 'Not selected') + '\n';
				output += 'and tone: ' + (formData.get('tone2') || 'Not selected') + '\n';
				output += 'and tone: ' + (formData.get('tone3') || 'Not selected') + '\n';
				output += 'In: ' + (formData.get('language') || 'Not selected') + '\n';
				output += 'Length: ' + (formData.get('length') || 'Not selected') + '\n';
				output += 'reasoning: ' + (formData.get('reasoning') || 'Not selected') + '\n';
				output += 'and: ' + (formData.get('reasoning2') || 'Not selected') + '\n';
				output += 'and: ' + (formData.get('reasoning3') || 'Not selected') + '\n';
				output += 'be: ' + (formData.get('objective') || 'Not selected') + '\n';
				output += 'and: ' + (formData.get('objective2') || 'Not selected') + '\n';
				output += 'and: ' + (formData.get('objective3') || 'Not selected') + '\n';

				output += 'Context: ' + (formData.get('context') || 'Not provided') + '\n';

				document.getElementById('data-text').textContent = output;
				document.getElementById('output').style.display = 'block';
			}

			function copyAll() {
				generateOutput();
				const output = document.getElementById('data-text');
				const range = document.createRange();
				range.selectNodeContents(output);
				const selection = window.getSelection();
				selection.removeAllRanges();
				selection.addRange(range);
				document.execCommand('copy');
				selection.removeAllRanges();
				alert('All data copied to clipboard!');
			}

			function exportPDF() {
				generateOutput();
				const { jsPDF } = window.jspdf;
				const doc = new jsPDF();
				const text = document.getElementById('data-text').textContent;
				doc.text(text, 10, 10);
				doc.save('legal-prompt.pdf');
			}

			window.onload = function () {
				document.getElementById('length').value = '1000 words';
				generateOutput();
			};
		</script>
