---
import { getNonprofitAiManualDocument } from '../../../utils/nonprofitAiManual';
import { normalizePageUrl, toAbsoluteUrl } from '../../../utils/site';

const meta = {
	title: 'Guia de IA para ONG en Quebec | Aiionwatha',
	description:
		'Guia practica de IA para organizaciones sin fines de lucro en Quebec con aplicaciones para subvenciones, recaudacion y operaciones.',
	url: 'https://aiionwatha.com/es/herramientas/ia-para-osfl',
	locale: 'es_ES',
	image: '/images/hero.webp',
	imageAlt: 'Guia de IA para organizaciones sin fines de lucro en Quebec'
};

const alternates = [
	{ href: 'https://aiionwatha.com/outils/ia-pour-obnl', hreflang: 'fr-CA' },
	{ href: 'https://aiionwatha.com/en/tools/ai-for-non-profits', hreflang: 'en-CA' },
	{ href: meta.url, hreflang: 'es-ES' },
	{ href: meta.url, hreflang: 'x-default' }
];

const document = getNonprofitAiManualDocument();
const canonicalUrl = normalizePageUrl(meta.url);
const imageUrl = toAbsoluteUrl(meta.image, canonicalUrl);
---

<!doctype html>
<html lang="es-ES">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<title>{meta.title}</title>
		<meta name="description" content={meta.description} />
		<meta name="robots" content="index,follow" />
		<link rel="canonical" href={canonicalUrl} />
		{alternates.map((alternate) => <link rel="alternate" hreflang={alternate.hreflang} href={normalizePageUrl(alternate.href)} />)}
		<meta property="og:type" content="article" />
		<meta property="og:locale" content={meta.locale} />
		<meta property="og:title" content={meta.title} />
		<meta property="og:description" content={meta.description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:alt" content={meta.imageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={meta.title} />
		<meta name="twitter:description" content={meta.description} />
		<meta name="twitter:image" content={imageUrl} />
		<Fragment set:html={document.head} />
	</head>
	<body>
		<Fragment set:html={document.body} />
		<script is:inline src="/manual-ai-obnl.js"></script>
	</body>
</html>
