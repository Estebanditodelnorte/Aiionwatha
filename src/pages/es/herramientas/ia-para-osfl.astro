---
import { getNonprofitAiManualDocument } from '../../../utils/nonprofitAiManual';

const meta = {
	title: 'IA para OSFL | Aiionwatha',
	description:
		'Manual práctico de IA para organizaciones sin fines de lucro con aplicaciones para estrategia, programas, recaudación y operaciones.',
	url: 'https://aiionwatha.com/es/herramientas/ia-para-osfl',
	locale: 'es_ES'
};

const alternates = [
	{ href: 'https://aiionwatha.com/outils/ia-pour-obnl', hreflang: 'fr-CA' },
	{ href: 'https://aiionwatha.com/en/tools/ai-for-non-profits', hreflang: 'en-CA' },
	{ href: meta.url, hreflang: 'es-ES' },
	{ href: meta.url, hreflang: 'x-default' }
];

const document = getNonprofitAiManualDocument();
---

<!doctype html>
<html lang="es-ES">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<title>{meta.title}</title>
		<meta name="description" content={meta.description} />
		<link rel="canonical" href={meta.url} />
		{alternates.map((alternate) => <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />)}
		<Fragment set:html={document.head} />
	</head>
	<body>
		<Fragment set:html={document.body} />
		<script is:inline src="/manual-ai-obnl.js"></script>
	</body>
</html>
